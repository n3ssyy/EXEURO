local function CreateTab(name, index)
    local btn = Instance.new("TextButton")
    btn.Name = name .. "_Btn"
    btn.Size = UDim2.new(1, -10, 0, 35)
    btn.BackgroundColor3 = C.Button
    btn.BorderSizePixel = 0
    btn.Text = name
    btn.TextColor3 = C.TextDim
    btn.Font = Enum.Font.GothamSemibold
    btn.TextSize = 13
    btn.LayoutOrder = index
    btn.Parent = TabsFrame
    btn.CornerRadius = UDim.new(0, 6)
    
    local content = Instance.new("Frame")
    content.Name = name .. "_Content"
    content.Size = UDim2.new(1, 0, 0, 500)
    content.BackgroundTransparency = 1
    content.BorderSizePixel = 0
    content.Visible = false
    content.LayoutOrder = index
    content.Parent = ScrollFrame
    
    local layout = Instance.new("UIListLayout")
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0, 10)
    layout.Parent = content
    
    btn.MouseButton1Click:Connect(function()
        -- Hide all tabs
        for _, t in ipairs(TabContents) do
            t.Visible = false
        end
        for _, b in ipairs(TabButtons) do
            b.BackgroundColor3 = C.Button
            b.TextColor3 = C.TextDim
        end
        -- Show selected
        content.Visible = true
        btn.BackgroundColor3 = C.AccentDark
        btn.TextColor3 = Color3.new(1, 1, 1)
        ActiveTab = content
    end)
    
    table.insert(TabButtons, btn)
    table.insert(TabContents, content)
    
    -- Select first tab
    if index == 1 then
        content.Visible = true
        btn.BackgroundColor3 = C.AccentDark
        btn.TextColor3 = Color3.new(1, 1, 1)
        ActiveTab = content
    end
    
    return content
end

