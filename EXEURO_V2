-- MAIN LOOP
-- ==========================================
RunService.RenderStepped:Connect(function()
    pcall(function()
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        -- Snow
        UpdateSnow(Config.Visuals.Snow)
        
        -- Aimbot / AutoShoot
        if Config.Aimbot.Enabled or Config.Aimbot.AutoShoot then
            local target = nil
            
            if Config.Aimbot.TargetMode == 1 then
                target = GetMurderer()
            elseif Config.Aimbot.TargetMode == 2 then
                -- Sheriff detection
                for _, p in ipairs(Players:GetPlayers()) do
                    if p ~= LocalPlayer and p.Character then
                        for _, item in ipairs(p.Character:GetChildren()) do
                            if item:IsA("Tool") and item.Name:lower():find("gun") then
                                target = p
                                break
                            end
                        end
                    end
                end
            else
                -- Find closest
                local closest = math.huge
                for _, p in ipairs(Players:GetPlayers()) do
                    if p ~= LocalPlayer and p.Character then
                        local dist = (hrp.Position - p.Character.HumanoidRootPart.Position).Magnitude
                        if dist < closest and dist < Config.Aimbot.FOV then
                            closest = dist
                            target = p
                        end
                    end
                end
            end
            
            if target and target.Character then
                local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
                local targetHead = target.Character:FindFirstChild("Head")
                local hitPart = Config.Aimbot.Hitbox == 1 and targetHead or targetHRP
                
                if hitPart then
                    if Config.Aimbot.AutoShoot and HasGun() then
                        Shoot()
                    end
                end
            end
        end
        
        -- TriggerBot
        if Config.Aimbot.TriggerBot and HasGun() then
            local ray = Workspace:Raycast(Camera.CFrame.Position, Camera.CFrame.LookVector * 1000)
            if ray and ray.Instance then
                local model = ray.Instance:FindFirstAncestorOfClass("Model")
                if model then
                    local player = Players:GetPlayerFromCharacter(model)
                    if player and player ~= LocalPlayer then
                        Shoot()
                    end
                end
            end
        end
        
        -- Anti Aim
        if Config.AntiAim.Enabled then
            if Config.AntiAim.Yaw == 3 then -- Spin
                SpinAngle = SpinAngle + Config.AntiAim.SpinSpeed
                hrp.CFrame = CFrame.new(hrp.Position) * CFrame.Angles(0, math.rad(SpinAngle), 0)
            elseif Config.AntiAim.Yaw == 2 then -- Backwards
                local camY = math.deg(Camera.CFrame.Yaw)
                hrp.CFrame = CFrame.new(hrp.Position) * CFrame.Angles(0, math.rad(camY + 180), 0)
            elseif Config.AntiAim.Yaw == 4 then -- Jitter
                local jitter = math.random(-Config.AntiAim.JitterRange/2, Config.AntiAim.JitterRange/2)
                local camY = math.deg(Camera.CFrame.Yaw)
                hrp.CFrame = CFrame.new(hrp.Position) * CFrame.Angles(0, math.rad(camY + jitter), 0)
            end
            
            -- Pitch
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then
                if Config.AntiAim.Pitch > 1 then
                    hum.AutoRotate = false
                else
                    hum.AutoRotate = true
                end
            end
        end
        
        -- Bhop
        if Config.Misc.Bhop and char:FindFirstChild("Humanoid") then
            local hum = char.Humanoid
            if hum:GetState() == Enum.HumanoidStateType.Freefall then
                hum.WalkSpeed = Config.Misc.BhopSpeed
            else
                hum.WalkSpeed = 16
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                hum.Jump = true
            end
        end
        
        -- ESP
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local highlight = p.Character:FindFirstChild("ExeuroHighlight")
                
                if Config.Visuals.ESP then
                    if not highlight then
                        highlight = Instance.new("Highlight")
                        highlight.Name = "ExeuroHighlight"
                        highlight.FillTransparency = 0.4
                        highlight.OutlineTransparency = 0.1
                        highlight.Parent = p.Character
                    end
                    
                    -- Color by role
                    local murderer = GetMurderer()
                    if murderer == p then
                        highlight.FillColor = Color3.fromRGB(255, 50, 50) -- Red for murderer
                    else
                        highlight.FillColor = Color3.fromRGB(50, 255, 50) -- Green for others
                    end
                    highlight.Enabled = true
                else
                    if highlight then
                        highlight:Destroy()
                    end
                end
            end
        end
        
    end)
end)

